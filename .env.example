# Copy this file to `.env` and fill in real values.
# `.env` is gitignored. Never commit real secrets.
# File mode for .env should be 600 (setup.sh enforces this).

# --- Discord ---------------------------------------------------------------

# Bot token from https://discord.com/developers/applications
# Keep this secret. Rotating it invalidates existing sessions.
DISCORD_TOKEN=

# Application ID (snowflake). Shown on the application "General Information" page.
DISCORD_APPLICATION_ID=

# Optional: guild ID used during development. When set, slash commands are
# registered to this single guild instead of globally (updates in <1s vs ~1h).
# Leave blank in production for global command registration.
DISCORD_TEST_GUILD_ID=

# --- Database --------------------------------------------------------------

# Populated automatically by setup.sh with a generated password.
# Format: postgres://<user>:<password>@<host>[:<port>]/<db>
DATABASE_URL=

# --- Logging ---------------------------------------------------------------

# tracing-subscriber filter. See https://docs.rs/tracing-subscriber
RUST_LOG=starship=info,warn

# --- RealmEye scraper ------------------------------------------------------

# User agent sent when scraping realmeye.com. Required: identify the bot + a
# contact channel so the site owner can reach out if there's an issue.
REALMEYE_USER_AGENT=starship-bot/0.1 (+github.com/yourname/starship)

