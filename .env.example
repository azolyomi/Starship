# Copy this file to `.env` and fill in real values.
# `.env` is gitignored. Never commit real secrets.
# File mode for .env should be 600 (setup.sh enforces this).

# --- Discord ---------------------------------------------------------------

# Bot token from https://discord.com/developers/applications
# Keep this secret. Rotating it invalidates existing sessions.
DISCORD_TOKEN=

# Application ID (snowflake). Shown on the application "General Information" page.
DISCORD_APPLICATION_ID=

# Optional: guild ID used during development. When set, slash commands are
# registered to this single guild instead of globally (updates in <1s vs ~1h).
# Leave blank in production for global command registration.
DISCORD_TEST_GUILD_ID=

# --- Database --------------------------------------------------------------

# Bare-metal dev: populated automatically by setup.sh with a generated
# password pointing at localhost:5432.
# Docker (docker-compose.yml): ignored — compose builds DATABASE_URL from
# the POSTGRES_* vars below so a single .env works on both hosts. You can
# leave this line blank in containerised deploys.
# Format: postgres://<user>:<password>@<host>[:<port>]/<db>
DATABASE_URL=

# --- Postgres (Docker deploy only) -----------------------------------------
# Only read by docker-compose.yml. Ignored by setup.sh (bare-metal dev uses
# the generated DATABASE_URL above instead).

# Postgres role + database name. Defaults below match setup.sh's values so
# you can `pg_dump` one side and restore on the other without renaming.
POSTGRES_USER=starship
POSTGRES_DB=starship

# REQUIRED for Docker deploys. Generate once with:
#   openssl rand -base64 33 | tr -d '/+=\n' | cut -c1-40
# Do NOT reuse the dev password from setup.sh — keep dev and prod
# credentials separate.
POSTGRES_PASSWORD=

# --- Logging ---------------------------------------------------------------

# tracing-subscriber filter. See https://docs.rs/tracing-subscriber
# Default (when unset): starship=info,serenity=warn,sqlx=warn,info
RUST_LOG=

# Log format: blank/anything (default) for human-readable, "json" for one
# JSON object per line. Use json under Docker / a log shipper; the human
# format is fine for `docker logs` / `journalctl` ad-hoc reading.
RUST_LOG_FORMAT=

# --- RealmEye scraper ------------------------------------------------------

# User agent sent when scraping realmeye.com. Required: identify the bot + a
# contact channel so the site owner can reach out if there's an issue.
# Quote the value if it contains parens or other shell metacharacters —
# deploy.sh and the pre-commit hook source .env in shell.
REALMEYE_USER_AGENT="starship-bot/0.1 (+github.com/yourname/starship)"

# --- Error reporting -------------------------------------------------------

# Comma-separated Discord user IDs that receive DM batches of WARN+ tracing
# events from services::error_dm. Leave empty to disable (no DMs are sent;
# the in-process layer becomes a no-op).
# Example: ERROR_DM_USER_IDS=123456789012345678,234567890123456789
ERROR_DM_USER_IDS=

